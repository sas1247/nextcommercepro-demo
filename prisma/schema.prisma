generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id                  String      @id @default(cuid())
  title               String
  slug                String      @unique
  shortDesc           String?
  description         String?
  sku                 String      @unique
  price               Int
  priceOld            Int?
  stock               Int         @default(0)
  inStock             Boolean     @default(true)
  isFeaturedDiscounts Boolean     @default(false)
  isFeaturedBest      Boolean     @default(false)
  categoryId          String
  image               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  persons             Int?
  pieces              Int?
  sheetType           String?
  modelType           String?
  size                String?
  places              Int?
  favorites           Favorite[]
  orderItems          OrderItem[]
  category            Category    @relation(fields: [categoryId], references: [id])
}

model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  createdAt   DateTime @default(now())
  voucherCode String?
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  amount      Int
  minSubtotal Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  usageLimit  Int       @default(1)
  usedCount   Int       @default(0)
}

model Order {
  id                    String      @id @default(cuid())
  orderNo               Int         @unique
  status                String      @default("NEW")
  personType            String
  pfName                String?
  pfPhone               String?
  pfEmail               String?
  pjCompany             String?
  pjCui                 String?
  pjRegCom              String?
  pjContact             String?
  pjPhone               String?
  pjEmail               String?
  county                String
  city                  String
  address               String
  zip                   String?
  notes                 String?
  paymentMethod         String
  currency              String      @default("USD")
  subtotal              Int
  discount              Int         @default(0)
  shipping              Int         @default(0)
  total                 Int
  couponCode            String?
  couponAmount          Int?
  couponMinSubtotal     Int?
  stripeSessionId       String?
  stripePaymentIntentId String?
  carrier               String?
  awb                   String?
  trackingUrl           String?
  userId                String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User?       @relation(fields: [userId], references: [id])
  items                 OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  title     String
  slug      String
  sku       String?
  image     String?
  price     Int
  qty       Int
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model User {
  id             String               @id @default(cuid())
  email          String               @unique
  passwordHash   String?
  firstName      String?
  lastName       String?
  phone          String?
  role           Role                 @default(USER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  addresses      Address[]
  billingProfile BillingProfile?
  favorites      Favorite[]
  oauth          OAuthAccount[]
  orders         Order[]
  resetTokens    PasswordResetToken[]
}

model Address {
  id        String      @id @default(cuid())
  userId    String
  type      AddressType
  isDefault Boolean     @default(false)
  company   String?
  cui       String?
  regCom    String?
  address1  String
  address2  String?
  city      String
  county    String
  zip       String?
  country   String      @default("RO")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Favorite {
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@index([productId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OAuthAccount {
  id         String   @id @default(cuid())
  userId     String
  provider   String
  providerId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

model BillingProfile {
  id         String   @id @default(cuid())
  userId     String   @unique
  personType String
  pfName     String?
  pfPhone    String?
  pfEmail    String?
  pjCompany  String?
  pjCui      String?
  pjRegCom   String?
  pjContact  String?
  pjPhone    String?
  pjEmail    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

enum AddressType {
  BILLING
  SHIPPING
}
